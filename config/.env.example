# LLM API 配置（在设置页填写 Base URL、Key 与模型）
LLM_API_BASE=https://api.openai.com/v1
LLM_API_KEY=sk-your-api-key-here
LLM_MODELS=auto
LLM_MODEL=gpt-4o-mini

# 自动更新（可选；默认见 config/update.json → Gitee patent-writing-assistant）
# PATENT_UPDATE_URL=https://gitee.com/quanzhouuniversity/patent-writing-assistant/raw/master
# 服务端口（仅本机）
SERVER_PORT=3847

# JWT 密钥（生产环境请修改）
JWT_SECRET=patent-assistant-change-me-in-production

# 默认管理员（首次启动自动创建）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# 反馈邮件 SMTP（也可在「设置」页配置）
FEEDBACK_SMTP_HOST=smtp.example.com
FEEDBACK_SMTP_PORT=587
FEEDBACK_SMTP_SECURE=false
FEEDBACK_SMTP_USER=your.email@example.com
FEEDBACK_SMTP_PASS=your-app-password
FEEDBACK_FROM=专利撰写助手 <your.email@example.com>
FEEDBACK_TO=13960565525@163.com
