{
  "name": "patent-assistant",
  "version": "1.3.13",
  "description": "专利撰写助手",
  "main": "electron/main.cjs",
  "author": "陈兴华 <13960565525@163.com>",
  "license": "GPL-3.0-only",
  "scripts": {
    "dev": "concurrently -k \"npm run dev:server\" \"npm run dev:client\" \"wait-on http://127.0.0.1:3847/api/health http://127.0.0.1:5173 && node scripts/launch-dev.cjs\"",
    "dev:server": "node server/src/index.js",
    "dev:client": "cd client && npm run dev",
    "build:client": "cd client && npm run build",
    "build": "npm run build:client && npm run build:icons && electron-builder --win --x64",
    "build:installer": "npm run build:icons && npm run build:client && electron-builder --win --x64",
    "build:dir": "npm run build:client && electron-builder --win --x64 --dir",
    "sync:brand-icons": "powershell -NoProfile -ExecutionPolicy Bypass -File build/sync-brand-icons.ps1",
    "build:icons": "npm run sync:brand-icons && powershell -NoProfile -ExecutionPolicy Bypass -File build/brand/make-icons.ps1 && node --input-type=module -e \"import fs from 'fs'; import pngToIco from 'png-to-ico'; const sizes=['icon-256.png','icon-128.png','icon-64.png','icon-48.png','icon-32.png','icon-16.png']; const buf=await pngToIco(sizes.map(s=>'build/brand/'+s)); fs.writeFileSync('build/icon.ico',buf); fs.copyFileSync('build/icon.ico','electron/icon.ico'); fs.copyFileSync('build/brand/icon-256.png','electron/icon.png');\"",
    "build:release": "npm run build && powershell -NoProfile -ExecutionPolicy Bypass -File build/stage-update.ps1",
    "publish:gitee": "powershell -NoProfile -ExecutionPolicy Bypass -File build/publish-gitee.ps1",
    "pack": "npm run build:client && electron-builder --win --x64 --dir",
    "postinstall": "cd client && npm install"
  },
  "build": {
    "appId": "com.patent.assistant",
    "productName": "patent-assistant",
    "electronBranding": {
      "projectName": "electron",
      "productName": "patent-assistant"
    },
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "electron/**/*",
      "server/**/*",
      "client/dist/**/*",
      "config/**/*",
      "!server/data/*.db-journal"
    ],
    "asarUnpack": [
      "client/dist/**/*",
      "server/**/*"
    ],
    "compression": "maximum",
    "extraResources": [
      {
        "from": "../patent-draft-android",
        "to": "patent-skill",
        "filter": [
          "SKILL.md",
          "README.md",
          "scripts/**/*",
          "templates/**/*",
          "workflows/**/*",
          "docs/**/*",
          "examples/**/*",
          "!desktop-releases/**",
          "!patent-draft-android-desktop-releases/**",
          "!**/*.exe",
          "!**/*.blockmap",
          "!**/latest.yml"
        ]
      },
      {
        "from": "build/post-install.ps1",
        "to": "post-install.ps1"
      },
      {
        "from": "config/.env.example",
        "to": "install-seed/.env.example"
      },
      {
        "from": "build/install-seed/ui.json",
        "to": "install-seed/ui.json"
      },
      {
        "from": "config/update.json",
        "to": "update-config/update.json"
      },
      {
        "from": "electron/icon.ico",
        "to": "app-icon.ico"
      },
      {
        "from": "build/brand/icon-32.png",
        "to": "tray-icon.png"
      },
      {
        "from": "build/update-splash.ps1",
        "to": "update-splash.ps1"
      }
    ],
    "publish": {
      "provider": "generic",
      "url": ""
    },
    "afterPack": "build/after-pack.cjs",
    "artifactName": "PatentAssistant-Setup-${version}.${ext}",
    "win": {
      "executableName": "patent-assistant",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "menuCategory": "专利撰写助手",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "createStartMenuShortcut": true,
      "shortcutName": "专利撰写助手",
      "include": "build/installer.nsh",
      "runAfterFinish": true,
      "deleteAppDataOnUninstall": false,
      "installerLanguages": [
        "zh_CN",
        "en_US"
      ],
      "language": "2052"
    }
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "electron-updater": "^6.8.9",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.2",
    "nodemailer": "^6.10.0",
    "uuid": "^11.0.5"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "electron": "^34.5.8",
    "electron-builder": "^25.1.8",
    "png-to-ico": "^3.0.1",
    "rcedit": "^5.0.2",
    "wait-on": "^8.0.2"
  }
}
